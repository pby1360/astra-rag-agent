# ── OpenAI ────────────────────────────────────────────────────────────────────
# GPT-4o 추론에 사용되는 OpenAI API 키
OPENAI_API_KEY=sk-...

# ── Redis Stack (벡터 DB) ─────────────────────────────────────────────────────
# MIL-SPEC 규격 임베딩을 저장하는 Redis Stack 연결 URL
# 형식: redis://[user:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# ── Neo4j (그래프 DB) ─────────────────────────────────────────────────────────
# 부품 의존성 그래프를 저장하는 Neo4j 연결 URI
# 형식: bolt://host:port 또는 neo4j+s://host:port (Aura)
NEO4J_URI=bolt://localhost:7687

# Neo4j 인증 사용자명
NEO4J_USER=neo4j

# Neo4j 인증 비밀번호
NEO4J_PASSWORD=your_password_here

# ── 임베딩 모델 설정 ──────────────────────────────────────────────────────────
# BGE-M3 모델 이름 (HuggingFace Hub 또는 로컬 경로)
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# ── 애플리케이션 설정 ─────────────────────────────────────────────────────────
# FastAPI 서버 환경 (development | production)
APP_ENV=development

# 로그 레벨 (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO

# Redis 인덱스 이름 (벡터 검색 인덱스)
REDIS_INDEX_NAME=mil_spec_index

# 벡터 검색 시 반환할 최대 결과 수
VECTOR_TOP_K=5
